{
  "name": "resume-forge",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered resume builder monorepo",
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:backend": "cd backend && ./mvnw spring-boot:run",
    "dev:frontend": "cd frontend && npm run dev",
    "build:backend": "cd backend && ./mvnw package -DskipTests",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm-run-all build:backend build:frontend",
    "test:backend": "cd backend && ./mvnw test",
    "test:frontend": "cd frontend && npm run build",
    "test": "npm-run-all test:backend test:frontend",
    "lint": "cd frontend && npm run lint",
    "clean": "rm -rf frontend/.next"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
