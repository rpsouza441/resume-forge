# =============================================================================
# Resume Forge - Environment Configuration
# Copie este arquivo para .env e preencha os valores.
# O .env NAO deve ser commitado (ja esta no .gitignore).
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/resumeforge
POSTGRES_DB=resumeforge
POSTGRES_USER=postgres
POSTGRES_HOST_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ─── JWT ────────────────────────────────────────────────────────────────────────
# IMPORTANTE: Altere para um valor seguro em producao.
JWT_SECRET=your-256-bit-secret-key-here-change-in-production

# ─── AI Provider ────────────────────────────────────────────────────────────
# Opcoes: gemini | openai | anthropic | openrouter
AI_PROVIDER=gemini
AI_API_KEY=your-api-key-here
AI_MODEL=gemini-2.0-flash
AI_TIMEOUT=90
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=8192

# ─── Server ─────────────────────────────────────────────────────────────────
# SERVER_PORT: porta interna do container backend (nao alterar).
SERVER_PORT=8080

# ─── CORS ─────────────────────────────────────────────────────────────────────
# As origens abaixo nao sao mais usadas em producao (same-origin via nginx),
# mas sao mantidas para debug direto ao backend bypassing o nginx.
# Formato: origens separadas por virgula, sem espacos.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3021,http://192.168.22.245:3021

# ─── Frontend ───────────────────────────────────────────────────────────────
# FRONTEND_PORT: porta interna do container frontend (nao alterar).
FRONTEND_PORT=3000

# ─── Nginx (Gateway Unico) ──────────────────────────────────────────────────
# NGINX_PORT: porta interna do nginx (nao alterar).
NGINX_PORT=80
# FRONTEND_HOST_PORT: porta EXTERNA do nginx — e o unico ponto de entrada.
# Para acesso local: 3021 (padrao)
# Para acesso por IP da rede: use o IP da maquina + esta porta
FRONTEND_HOST_PORT=3021

# ─── API URL do Frontend ────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL agora aponta para o nginx local (mesma origem do Next.js).
# Com URL relativa no bundle, este valor e usado apenas em desenvolvimento
# local sem Docker (quando o Next.js serve em localhost:3000).
NEXT_PUBLIC_API_URL=http://localhost:3080
